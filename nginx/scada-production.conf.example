# Mẫu cấu hình nginx trên server (SSL) cho https://scada.plenmaiot.com
# Sao chép vào sites-available, chỉnh đường dẫn root và upstream backend.

server {
    listen 443 ssl http2;
    server_name scada.plenmaiot.com;

    # ssl_certificate ...
    # ssl_certificate_key ...

    root /var/www/25057/25057_Offical/frontend/dist;
    index index.html;

    location /api/ {
        proxy_pass http://127.0.0.1:3000/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /uploads/ {
        proxy_pass http://127.0.0.1:3000/uploads/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}
