    "@arcjet/node": "^1.0.0-beta.7",
    "@neondatabase/serverless": "^1.0.0",
    "chartjs-plugin-zoom": "^2.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "lucide-react": "^0.548.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.1",
    "pg": "^8.16.0",
    "react-datepicker": "^8.4.0",
    "redis": "^5.5.5"
